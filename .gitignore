# ============================================================
# ANDA AKE — .gitignore
# ============================================================

# -------------------------
# Dart / Flutter
# -------------------------
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
*.iml

# Generated Dart files
*.g.dart
*.freezed.dart
*.mocks.dart

# pubspec.lock — committed for app (not library)
# pubspec.lock

# -------------------------
# IDE / Editor
# -------------------------
.idea/
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

safety_critical/


# -------------------------
# Firebase / Secrets
# -------------------------
# These files contain API keys — NEVER commit them.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart
.firebaserc

# Cloud Functions dependencies
functions/node_modules/

# Firebase emulator data
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
database-debug.log

# -------------------------
# Android
# -------------------------
android/app/build/
android/.gradle/
android/gradle/
android/gradlew
android/gradlew.bat
android/local.properties
android/key.properties
android/app/*.jks
android/app/*.keystore
android/captures/

# -------------------------
# iOS
# -------------------------
ios/Flutter/App.framework
ios/Flutter/engine.version
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_assets.xcconfig
ios/Flutter/.last_build_id
ios/.symlinks/
ios/Pods/
ios/Podfile.lock
ios/Runner.xcworkspace/
ios/Runner.xcarchive/
ios/build/
ios/DerivedData/

# -------------------------
# Windows
# -------------------------
windows/flutter/ephemeral/
windows/flutter/generated_plugins.cmake
windows/build/

# -------------------------
# macOS
# -------------------------
macos/Flutter/ephemeral/
macos/Flutter/Generated.xcconfig
macos/Flutter/flutter_export_environment.sh
macos/.symlinks/
macos/Pods/
macos/Podfile.lock
macos/Runner.xcworkspace/
macos/build/

# -------------------------
# Linux
# -------------------------
linux/flutter/ephemeral/
linux/flutter/generated_plugins.cmake
linux/build/

# -------------------------
# Web
# -------------------------
web/build/

# -------------------------
# OS Junk
# -------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.bak

# -------------------------
# Debug / Log files
# -------------------------
# All log and debug files generated during development
*.log
*.txt
!README.md

# -------------------------
# Metadata
# -------------------------
.metadata
